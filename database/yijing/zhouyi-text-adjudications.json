  "records": [
    { "id": "13:九五", "sequence": 13, "position": "九五", "status": "corrected_dual_witness", "selected": "同人先号啕而后笑，大师克相遇", "previous": "同人先号咷而后笑，大师克相遇", "ctextPath": "tong-ren/zhs" },
    { "id": "14:上九", "sequence": 14, "position": "上九", "status": "corrected_dual_witness", "selected": "自天佑之，吉无不利", "previous": "自天祐之，吉无不利", "ctextPath": "da-you/zhs" },
    { "id": "24:初九", "sequence": 24, "position": "初九", "status": "wikisource_transcription_divergence", "selected": "不远复，无祇悔，元吉", "wikisource": "不复远，无袛悔，元吉。", "ctext": "不远复，无祗悔，元吉。", "ctextPath": "fu/zhs" },
    { "id": "26:九二", "sequence": 26, "position": "九二", "status": "corrected_dual_witness", "selected": "舆说輹", "previous": "舆说辐", "ctextPath": "da-xu/zhs" },
    { "id": "26:九三", "sequence": 26, "position": "九三", "status": "corrected_dual_witness", "selected": "良马逐，利艰贞，曰闲舆卫，利有攸往", "previous": "良马逐，利艰贞，日闲舆卫，利有攸往", "ctextPath": "da-xu/zhs" },
    { "id": "29:九五", "sequence": 29, "position": "九五", "status": "corrected_dual_witness", "selected": "坎不盈，祗既平，无咎", "previous": "坎不盈，祇既平，无咎", "ctextPath": "kan/zhs" },
    { "id": "33:初六", "sequence": 33, "position": "初六", "status": "simplified_received_variant", "selected": "遁尾，厉，勿用有攸往", "witnessVariant": "遯尾，厉，勿用有攸往。", "ctextPath": "dun/zhs" },
    { "id": "33:九三", "sequence": 33, "position": "九三", "status": "simplified_received_variant", "selected": "系遁，有疾厉，畜臣妾吉", "witnessVariant": "系遯，有疾厉，畜臣妾吉。", "ctextPath": "dun/zhs" },
    { "id": "33:九四", "sequence": 33, "position": "九四", "status": "simplified_received_variant", "selected": "好遁，君子吉，小人否", "witnessVariant": "好遯君子吉，小人否。", "ctextPath": "dun/zhs" },
    { "id": "33:九五", "sequence": 33, "position": "九五", "status": "simplified_received_variant", "selected": "嘉遁，贞吉", "witnessVariant": "嘉遯，贞吉。", "ctextPath": "dun/zhs" },
    { "id": "33:上九", "sequence": 33, "position": "上九", "status": "simplified_received_variant", "selected": "肥遁，无不利", "witnessVariant": "肥遯，无不利。", "ctextPath": "dun/zhs" },
    { "id": "44:初六", "sequence": 44, "position": "初六", "status": "wikisource_variant_ctext_supports_local", "selected": "系于金柅，贞吉，有攸往见凶，羸豕孚蹢躅", "wikisource": "系于金柅，贞吉，有攸往，见凶，羸豕孚踟躅。", "ctextPath": "gou/zhs" },
    { "id": "47:九二", "sequence": 47, "position": "九二", "status": "wikisource_transcription_divergence", "selected": "困于酒食，朱绂方来，利用享祀，征凶，无咎", "wikisource": "困于酒食，朱绂方来，利用亨祀，征凶，无咎。", "ctextPath": "kun1/zhs" },
    { "id": "47:六三", "sequence": 47, "position": "六三", "status": "corrected_dual_witness", "selected": "困于石，据于蒺藜，入于其宫不见其妻，凶", "previous": "困于石，据于蒺藜，入其宫不见其妻，凶", "ctextPath": "kun1/zhs" },
    { "id": "49:卦辞", "sequence": 49, "position": "卦辞", "status": "unresolved_received_text_variant", "selected": "已日乃孚，元亨利贞，悔亡。", "wikisource": "巳日乃孚，元亨。利贞。悔亡。", "ctextPath": "ge/zhs", "note": "已、巳、己三字存在真实版本与训诂分歧；保留当前受文文本，不标为唯一定本。" },
    { "id": "49:六二", "sequence": 49, "position": "六二", "status": "unresolved_received_text_variant", "selected": "已日乃革之，征吉，无咎", "wikisource": "巳日乃革之，征吉，无咎。", "ctextPath": "ge/zhs", "note": "与本卦卦辞同属已/巳/己版本分歧。" },
    { "id": "55:九三", "sequence": 55, "position": "九三", "status": "wikisource_transcription_divergence", "selected": "丰其沛，日中见沬，折其右肱，无咎", "wikisource": "丰其沛，日中见沫，折其右肱，无咎。", "ctextPath": "feng/zhs" },
    { "id": "61:初九", "sequence": 61, "position": "初九", "status": "accepted_character_variant_ctext_supports_local", "selected": "虞吉，有它不燕", "wikisource": "虞吉，有他不燕。", "ctextPath": "zhong-fu/zhs" },
    { "id": "61:九二", "sequence": 61, "position": "九二", "status": "corrected_dual_witness", "selected": "鸣鹤在阴，其子和之，我有好爵，吾与尔靡之", "previous": "鹤鸣在阴，其子和之，我有好爵，吾与尔靡之", "ctextPath": "zhong-fu/zhs" }
