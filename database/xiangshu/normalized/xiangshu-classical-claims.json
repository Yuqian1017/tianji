    {
      "id": "face.five_mountains.locations",
      "domain": "face",
      "topic": "five_mountains",
      "originalText": "左顴為東嶽，額為南嶽，右顴為西嶽，地閣為北嶽，土星為中嶽。",
      "normalizedClaim": "《神相全编》此处把左颧、额、右颧、地阁和鼻分别称为东、南、西、北、中岳。",
      "sourceRefIds": ["sxqb-905153-p14-five-mountains"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_mountains.traditional_association",
      "domain": "face",
      "topic": "five_mountains",
      "originalText": "五嶽俱朝，貴壓朝班，亦且錢財自旺。",
      "normalizedClaim": "《神相全编》把“五岳俱朝”与贵、财旺相联系。",
      "sourceRefIds": ["sxqb-905153-p14-five-mountains"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_elements.forms",
      "domain": "face",
      "topic": "five_element_face_forms",
      "originalText": "金形方正色潔白，木形瘦直骨節堅，水形圓厚重而黑，火形豐銳赤焦燥，土形敦厚色黃光。",
      "normalizedClaim": "《神相全编》以方正、瘦直、圆厚、丰锐、敦厚等形态描述金木水火土五形。",
      "sourceRefIds": ["sxqb-905153-p50-five-element-forms"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_elements.traditional_associations",
      "domain": "face",
      "topic": "five_element_face_forms",
      "originalText": "金得金剛毅深，木得木資財足，水得水文章貴，火得火見機果，土得土厚豐庫。",
      "normalizedClaim": "《神相全编》此段分别把五形与刚毅、资财、文章、见机、丰库等传统判断相联系。",
      "sourceRefIds": ["sxqb-905153-p29-five-elements"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "palm.bagua.locations",
      "domain": "palm",
      "topic": "palm_bagua",
      "originalText": "掌有八卦，而最緊要在巽、離、坤三宮。",
      "normalizedClaim": "《神相铁关刀》相掌秘诀以八卦分掌，并特别提出巽、离、坤三宫。",
      "sourceRefIds": ["sxtgd-351787-p22-bagua"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "palm.bagua.traditional_associations",
      "domain": "palm",
      "topic": "palm_bagua",
      "originalText": "巽主財帛，離主功名，坤主子嗣。",
      "normalizedClaim": "该见证分别把巽、离、坤三宫与财帛、功名、子嗣相联系。",
      "sourceRefIds": ["sxtgd-351787-p22-bagua"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "palm.size.traditional_association",
      "domain": "palm",
      "topic": "palm_form",
      "originalText": "掌小者貴，掌大者勞。",
      "normalizedClaim": "《神相铁关刀》此处把掌小与贵、掌大与劳相联系。",
      "sourceRefIds": ["sxtgd-351787-p23-palm-form"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "palm.lines.direction_associations",
      "domain": "palm",
      "topic": "palm_lines",
      "originalText": "直紋多，人必聰明；橫紋多，人必心紛。",
      "normalizedClaim": "《神相铁关刀》此处把直纹多与聪明、横纹多与心纷相联系。",
      "sourceRefIds": ["sxtgd-351787-p24-lines"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "palm.form.five_elements",
      "domain": "palm",
      "topic": "five_element_hand_forms",
      "originalText": "木形宜長直。金形宜方正。水形宜圓短。土形宜敦厚。火形宜尖露。",
      "normalizedClaim": "《公笃相法》手掌图说给出木长直、金方正、水圆短、土敦厚、火尖露的五形分类。",
      "sourceRefIds": ["gdxfx-419831-p19-five-forms"],
