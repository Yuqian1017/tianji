      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.three_stops.equal",
      "domain": "face",
      "topic": "three_stops",
      "originalText": "三停平等，一生衣祿無虧。",
      "normalizedClaim": "《神相全编》此处把三停平等与一生衣禄无亏相联系。",
      "sourceRefIds": ["sxqb-905153-p14-three-stops"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.three_stops.upper_long",
      "domain": "face",
      "topic": "three_stops",
      "originalText": "上停長少年忙。",
      "normalizedClaim": "《神相全编》此处记上停长为“少年忙”。",
      "sourceRefIds": ["sxqb-905153-p14-three-stops"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.three_stops.middle_long",
      "domain": "face",
      "topic": "three_stops",
      "originalText": "中停長福祿昌。",
      "normalizedClaim": "《神相全编》此处把中停长与福禄昌相联系。",
      "sourceRefIds": ["sxqb-905153-p14-three-stops"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.three_stops.lower_long",
      "domain": "face",
      "topic": "three_stops",
      "originalText": "下停長老吉祥。",
      "normalizedClaim": "《神相全编》此处把下停长与年老吉祥相联系。",
      "sourceRefIds": ["sxqb-905153-p14-three-stops"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.three_stops.no_single_factor",
      "domain": "face",
      "topic": "three_stops",
      "originalText": "可照流年部位氣色而推，不可一體而斷。",
      "normalizedClaim": "该见证自身提醒不能只凭单一形态一概而断。",
      "sourceRefIds": ["sxqb-905153-p14-three-stops"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_mountains.locations",
      "domain": "face",
      "topic": "five_mountains",
      "originalText": "左顴為東嶽，額為南嶽，右顴為西嶽，地閣為北嶽，土星為中嶽。",
      "normalizedClaim": "《神相全编》此处把左颧、额、右颧、地阁和鼻分别称为东、南、西、北、中岳。",
      "sourceRefIds": ["sxqb-905153-p14-five-mountains"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_mountains.traditional_association",
      "domain": "face",
      "topic": "five_mountains",
      "originalText": "五嶽俱朝，貴壓朝班，亦且錢財自旺。",
      "normalizedClaim": "《神相全编》把“五岳俱朝”与贵、财旺相联系。",
      "sourceRefIds": ["sxqb-905153-p14-five-mountains"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_elements.forms",
      "domain": "face",
      "topic": "five_element_face_forms",
      "originalText": "金形方正色潔白，木形瘦直骨節堅，水形圓厚重而黑，火形豐銳赤焦燥，土形敦厚色黃光。",
      "normalizedClaim": "《神相全编》以方正、瘦直、圆厚、丰锐、敦厚等形态描述金木水火土五形。",
      "sourceRefIds": ["sxqb-905153-p50-five-element-forms"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.five_elements.traditional_associations",
      "domain": "face",
      "topic": "five_element_face_forms",
      "originalText": "金得金剛毅深，木得木資財足，水得水文章貴，火得火見機果，土得土厚豐庫。",
      "normalizedClaim": "《神相全编》此段分别把五形与刚毅、资财、文章、见机、丰库等传统判断相联系。",
      "sourceRefIds": ["sxqb-905153-p29-five-elements"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.ming.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "命宮者，居兩眉之間，山根之上。",
      "normalizedClaim": "《神相全编》把命宫定位在两眉之间、山根之上。",
      "sourceRefIds": ["sxqb-905153-p308-ming-palace"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.wealth.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "鼻乃財星，位居土宿。",
      "normalizedClaim": "《神相全编》十二宫财帛段以鼻为财星。",
      "sourceRefIds": ["sxqb-905153-p313-wealth-palace"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.siblings.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "兄弟位居兩眉，屬羅計。",
      "normalizedClaim": "《神相全编》把兄弟宫定位在两眉。",
      "sourceRefIds": ["sxqb-905153-p318-siblings-palace"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.property.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "田宅者，立居兩眼。",
      "normalizedClaim": "《神相全编》当前见证把田宅宫定位为两眼，而不是旧库所写的眉眼之间。",
      "sourceRefIds": ["sxqb-905153-p323-property-palace"],
      "interpretationStatus": "exact_witness_conflicts_with_compendium",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.children.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "男女者，位居兩眼之下，名曰淚堂。",
      "normalizedClaim": "《神相全编》以“男女宫”称子女相关宫位，定位在两眼之下的泪堂。",
      "sourceRefIds": ["sxqb-905153-p328-children-palace"],
      "interpretationStatus": "exact_witness_with_modern_alias",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.servants.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "奴僕者，位居地閣，重接水星。頰圓豐滿，侍立成群。",
      "normalizedClaim": "《神相全编》以“奴仆宫”称该宫位，涉及地阁、水星和两颊；旧库“交友宫=腮部”是后来的改名和缩写。",
      "sourceRefIds": ["sxqb-905153-p333-servants-palace"],
      "interpretationStatus": "witness_with_modern_alias_and_simplification",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.spouse.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "妻妾者，位居魚尾，號曰奸門。",
      "normalizedClaim": "《神相全编》以“妻妾宫”称该宫位，定位在鱼尾、奸门。",
      "sourceRefIds": ["sxqb-905153-p338-spouse-palace"],
      "interpretationStatus": "exact_witness_with_modern_alias",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.illness.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "疾厄者，印堂之下，位居山根。",
      "normalizedClaim": "《神相全编》把疾厄宫定位在印堂之下、山根；这里只授证传统位置，不授证医学诊断。",
      "sourceRefIds": ["sxqb-905153-p343-illness-palace"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.migration.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "遷移者，位居眉角，號曰天倉。",
      "normalizedClaim": "《神相全编》把迁移宫定位在眉角，又称天仓。",
      "sourceRefIds": ["sxqb-905153-p348-migration-palace"],
      "interpretationStatus": "exact_witness",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.office.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "官祿者，位居中正，上合離宮。",
      "normalizedClaim": "《神相全编》把官禄宫定位在中正，上合离宫；旧库“额头中央”只是粗略转述。",
      "sourceRefIds": ["sxqb-905153-p353-office-palace"],
      "interpretationStatus": "exact_witness_with_broad_compendium_paraphrase",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.fortune.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "福德者，位居天倉，牽連地閣。",
      "normalizedClaim": "《神相全编》把福德宫定位在天仓并牵连地阁；旧库“眉尾上方”只覆盖天仓的一部分。",
      "sourceRefIds": ["sxqb-905153-p358-fortune-palace"],
      "interpretationStatus": "exact_witness_with_incomplete_compendium_paraphrase",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.appearance.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "相貌者，先觀五岳，次辨三停。",
      "normalizedClaim": "《神相全编》编号十二宫的第十二项是相貌宫，以五岳和三停为整体观察对象。",
      "sourceRefIds": ["sxqb-905153-p363-appearance-palace"],
      "interpretationStatus": "exact_witness_missing_from_compendium_table",
      "runtimePolicy": "cultural_learning_with_citation",
      "runtimeEligible": true
    },
    {
      "id": "face.palaces.parents.location",
      "domain": "face",
      "topic": "twelve_palaces",
      "originalText": "父母宮論曰：日月角須要高。",
      "normalizedClaim": "《神相全编》在“十二宫总诀”中另列父母宫，观察日月角；它不是当前见证编号十二宫中的第十二项。",
