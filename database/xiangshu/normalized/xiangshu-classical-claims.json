    {
      "id": "face.three_stops.definition",
      "domain": "face",
      "topic": "three_stops",
      "originalText": "三停者，額門，准頭，地角，此面部三停也。",
      "normalizedClaim": "该见证以额门、准头、地角划分面部三停。",
