      "canonicalClaimIds": [],
      "reason": "《神相全编》支持五岳的身体位置，但本轮见证未支持旧表为每一岳配置的现代主管事项。",
      "runtimeEligible": false
    },
    {
      "id": "compendium.face.five_mountains.fortune",
      "rawLocator": "10-xiangshu/01-mianxiang.md:33-34",
      "rawText": "五岳丰隆：一生富贵；某岳凹陷/偏斜：对应方面运势受损",
