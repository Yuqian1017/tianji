    {
      "id": "compendium.face.three_stops.equal",
      "rawLocator": "10-xiangshu/01-mianxiang.md:18",
      "rawText": "三停均匀：一生运势平稳",
      "status": "close_paraphrase",
      "canonicalClaimIds": ["face.three_stops.equal"],
      "reason": "见证原文为“三停平等，一生衣禄无亏”；旧文扩大成笼统的运势平稳，产品应显示原文或明确标注转述。",
      "runtimeEligible": true
    },
    {
      "id": "compendium.face.three_stops.upper",
      "rawLocator": "10-xiangshu/01-mianxiang.md:19",
      "rawText": "上停长：少年得志·学业佳·但中晚年可能平淡",
      "status": "conflicts_with_located_witness",
      "canonicalClaimIds": [],
      "reason": "本轮定位的《神相全编》写作“上停长少年忙”，未支持少年得志、学业佳及中晚年平淡。",
      "runtimeEligible": false
    },
    {
      "id": "compendium.face.three_stops.middle",
      "rawLocator": "10-xiangshu/01-mianxiang.md:20",
      "rawText": "中停长：事业心强·中年发力·自主能力强",
      "status": "modern_extrapolation_not_located",
      "canonicalClaimIds": [],
      "reason": "已定位见证仅作“中停长福禄昌”，不支持具体人格、事业阶段和自主能力扩写。",
      "runtimeEligible": false
    },
    {
      "id": "compendium.face.three_stops.lower",
      "rawLocator": "10-xiangshu/01-mianxiang.md:21",
      "rawText": "下停长：晚年有福·子女孝顺·物质丰足",
      "status": "partly_supported_with_extra_claims",
      "canonicalClaimIds": [],
      "reason": "“下停长老吉祥”只近似支持晚年吉祥；子女孝顺和物质丰足尚未在本轮见证中定位。",
      "runtimeEligible": false
    },
    {
      "id": "compendium.face.five_mountains.locations",
      "rawLocator": "10-xiangshu/01-mianxiang.md:27-31",
      "rawText": "五岳位置及社交、权力、名声、根基、财运等逐岳主管",
