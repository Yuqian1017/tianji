  "usefulDesignElements": [
    "pseudonymous case labels and explicit privacy reminders",
    "relations among chart cases, pre-event claims, observed outcomes, and methods",
    "falsifiable claim guidance with a time window and non-occurrence condition",
    "preservation of failed claims instead of deleting them",
    "local-first Markdown option with portable structured fields"
  ],
  "designFindings": [
    {
      "id": "authority-and-outcomes-conflated",
      "severity": "blocking_for_direct_adoption",
      "finding": "The single reliability field mixes classical attestation, personal outcome history, trial state, and doubt; these are different evidence dimensions."
    },
    {
      "id": "small-sample-promotion",
      "severity": "blocking_for_direct_adoption",
      "finding": "Three positive records can promote a method to verified; this cannot establish general validity and omits base rates, selection effects, and unresolved observations."
    },
    {
      "id": "claim-freeze-missing",
      "severity": "blocking_for_direct_adoption",
      "finding": "The workflow encourages pre-event claims but does not define immutable claim versions, lock time, edit history, or proof that the claim preceded the outcome."
    },
    {
      "id": "adjudication-subjective",
      "severity": "requires_adaptation",
      "finding": "Supported and partially supported ratings lack an event ontology, independent reviewer contract, evidence class, and default metric treatment."
    },
    {
      "id": "chart-provenance-missing",
      "severity": "requires_adaptation",
      "finding": "Chart records omit engine version, school contract, civil-time precision, timezone, and source snapshot needed to reproduce a reading."
    },
    {
      "id": "privacy-foundation-useful",
      "severity": "positive",
      "finding": "Pseudonyms, optional exact birth data, fictional examples, and cloud-versus-local privacy reminders are sound defaults to retain."
    }
  ],
